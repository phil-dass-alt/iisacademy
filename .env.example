# Supabase (shared by both iisacademy.in and iiskills.cloud)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# Site identity – controls which feature flags are active.
# Set to "iisacademy" or "iiskills".  Defaults to "iisacademy" when unset.
NEXT_PUBLIC_SITE_ID=iisacademy

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# AI (OpenAI or equivalent)
OPENAI_API_KEY=sk-your-openai-api-key

# Analytics
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# ── iisacademy.in URLs ────────────────────────────────────────────────────────
NEXT_PUBLIC_LANDING_URL=http://localhost:3000
NEXT_PUBLIC_STUDENT_PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_B2B_URL=http://localhost:3003

# ── iiskills.cloud URLs ───────────────────────────────────────────────────────
NEXT_PUBLIC_SKILLS_LANDING_URL=http://localhost:3000
NEXT_PUBLIC_SKILLS_PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_SKILLS_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_SKILLS_B2B_URL=http://localhost:3003

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@iisacademy.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/iisacademy

# Membership
MEMBERSHIP_PRICE_INR=499
MEMBERSHIP_PLAN_NAME=High-5

# Payment gateway callback (shared secret between iisacademy.in and aienter.in)
# Used to validate HMAC-SHA256 signatures on payment notifications.
# Must be a long, random string – generate with: openssl rand -hex 32
PAYMENT_CALLBACK_SECRET=your-payment-callback-secret-min-32-chars


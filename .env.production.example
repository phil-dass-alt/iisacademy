# IIS Academy / IIS Skills – Production Environment Variables
# Copy to .env.production and fill in all values before deploying.
#
# NEVER commit .env.production to git.
# On the VPS: keep this file at /srv/iisacademy/.env.production (chmod 600)
# For Docker: pass via --env-file flag (see docker-compose.yml)

# ── Supabase (shared by iisacademy.in AND iiskills.cloud) ────────────────────
# From: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# Per-app NextAuth URLs (must match the domain each app is served from)
NEXTAUTH_LANDING_URL=https://iisacademy.in
NEXTAUTH_PORTAL_URL=https://portal.iisacademy.in
NEXTAUTH_ADMIN_URL=https://admin.iisacademy.in
NEXTAUTH_B2B_URL=https://b2b.iisacademy.in

# iiskills.cloud per-app NextAuth URLs
NEXTAUTH_SKILLS_LANDING_URL=https://iiskills.cloud
NEXTAUTH_SKILLS_PORTAL_URL=https://portal.iiskills.cloud
NEXTAUTH_SKILLS_ADMIN_URL=https://admin.iiskills.cloud
NEXTAUTH_SKILLS_B2B_URL=https://b2b.iiskills.cloud

# ── Site identity ─────────────────────────────────────────────────────────────
# Injected per Docker service to control which feature flags are active.
# iisacademy containers set NEXT_PUBLIC_SITE_ID=iisacademy (the default).
# iiskills containers (if run separately) set NEXT_PUBLIC_SITE_ID=iiskills.
# When using domain-based detection (single Docker stack, both sites served
# by the same containers) this value can be omitted; the app infers the site
# from the Host header automatically via getSiteId() in packages/auth.
NEXT_PUBLIC_SITE_ID=iisacademy

# ── Google OAuth (optional – for Google sign-in) ─────────────────────────────
# Create at: https://console.cloud.google.com → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── iisacademy.in public URLs ─────────────────────────────────────────────────
NEXT_PUBLIC_LANDING_URL=https://iisacademy.in
NEXT_PUBLIC_STUDENT_PORTAL_URL=https://portal.iisacademy.in
NEXT_PUBLIC_ADMIN_URL=https://admin.iisacademy.in
NEXT_PUBLIC_B2B_URL=https://b2b.iisacademy.in

# ── iiskills.cloud public URLs ────────────────────────────────────────────────
NEXT_PUBLIC_SKILLS_LANDING_URL=https://iiskills.cloud
NEXT_PUBLIC_SKILLS_PORTAL_URL=https://portal.iiskills.cloud
NEXT_PUBLIC_SKILLS_ADMIN_URL=https://admin.iiskills.cloud
NEXT_PUBLIC_SKILLS_B2B_URL=https://b2b.iiskills.cloud

# ── Razorpay (Production keys) ────────────────────────────────────────────────
# Replace rzp_test_ with rzp_live_ for production
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-live-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# ── Payment callback secret ───────────────────────────────────────────────────
# Shared HMAC-SHA256 secret between iisacademy.in and aienter.in
# Generate: openssl rand -hex 32
PAYMENT_CALLBACK_SECRET=your-payment-callback-secret-min-32-chars

# ── AI / OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ── Analytics ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@iisacademy.in

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/iisacademy

# ── Membership ───────────────────────────────────────────────────────────────
MEMBERSHIP_PRICE_INR=499
MEMBERSHIP_PLAN_NAME=High-5

# ── Testing flags ─────────────────────────────────────────────────────────────
# Set BYPASS_SUBSCRIPTION_CHECK=true during QA to allow any logged-in user
# to access the portal without a Supabase subscription record.
# IMPORTANT: Set to false (or remove) before opening to real users.
BYPASS_SUBSCRIPTION_CHECK=false

# ── Docker image tag ──────────────────────────────────────────────────────────
IMAGE_TAG=latest
